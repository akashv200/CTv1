# -----------------------------------------------------------------------------
# CORE PLATFORM (Managed by AI Studio)
# -----------------------------------------------------------------------------
# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime.
APP_URL="MY_APP_URL"

# -----------------------------------------------------------------------------
# DATABASE & INFRASTRUCTURE (Local Docker / Remote)
# -----------------------------------------------------------------------------
# PG_URL: PostgreSQL connection string. 
# Local default: postgresql://postgres:postgres@localhost:5432/chaintrace
PG_URL="postgresql://postgres:AkAkAk007@localhost:5432/chaintrace"
PG_SSL="false"

# REDIS_URL: Redis cache connection string.
# Local default: redis://localhost:6379
REDIS_URL="redis://localhost:6379"

# MQTT_URL: MQTT Broker URL for IoT data.
# Local default: mqtt://localhost:1883
MQTT_URL="mqtt://localhost:1883"

# -----------------------------------------------------------------------------
# BLOCKCHAIN (Ganache / Hardhat / Testnet)
# -----------------------------------------------------------------------------
# EVM_RPC_URL: Blockchain node RPC URL.
# Ganache default: http://127.0.0.1:7545
EVM_RPC_URL="http://127.0.0.1:7545"

# CHAIN_ID: Network chain ID.
# Ganache default: 5777
CHAIN_ID="5777"

# TRACEABILITY_CONTRACT: Deployed contract address.
TRACEABILITY_CONTRACT=""

# EVM_PRIVATE_KEY: Deployer or operator private key.
EVM_PRIVATE_KEY=""

# -----------------------------------------------------------------------------
# AUTH & INTEGRATION
# -----------------------------------------------------------------------------
# JWT_SECRET: Minimum 8 characters.
JWT_SECRET="change_this_secret_in_production"

# VITE_API_BASE_URL: Frontend connection to Backend API.
# In AI Studio, this is usually your APP_URL + /api
VITE_API_BASE_URL=""

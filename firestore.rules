rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Phase 3: Agriculture Supply Chain RLS
    // ===============================================================
    // Data Model:
    // - products: {id, name, sku, origin, farmerId, status, blockchainTxHash, qrCodeUrl, checkpointCount}
    // - checkpoints: {id, productId, location, timestamp, handler, status, blockchainTxHash}
    // - users: {id, email, role, organizationId, status}
    // - revokedTokens: {tokenHash, userId, revokedAt, expiresAt}
    //
    // Roles: farmer, logistics, auditor, super_admin, public (no auth)

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isFarmer() {
      return isAuthenticated() && request.auth.token.role == 'farmer';
    }

    function isLogistics() {
      return isAuthenticated() && request.auth.token.role in ['logistics', 'distributor'];
    }

    function isAuditor() {
      return isAuthenticated() && request.auth.token.role in ['auditor', 'super_admin'];
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Products Collection (Agriculture)
    // ===============================================================
    match /products/{productId} {
      // Phase 3: PUBLIC READ - anyone can verify products (no auth required)
      // This enables the /verify endpoint to work for QR code scanning
      allow read: if true;
      
      // Phase 3: FARMER WRITE - farmers can create products
      allow create: if isFarmer() 
        && request.resource.data.farmerId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.origin is string
        && request.resource.data.sku is string;
      
      // Phase 3: FARMER UPDATE - farmers can update their own products
      allow update: if isFarmer()
        && resource.data.farmerId == request.auth.uid;
      
      // Phase 3: FARMER DELETE - farmers can delete their own products
      allow delete: if isFarmer()
        && resource.data.farmerId == request.auth.uid;
    }

    // ===============================================================
    // Checkpoints Collection (Logistics)
    // ===============================================================
    match /checkpoints/{checkpointId} {
      // Phase 3: PUBLIC READ - anyone can view checkpoint timeline for verification
      allow read: if true;
      
      // Phase 3: LOGISTICS WRITE - logistics handlers can add checkpoints
      allow create: if isLogistics()
        && request.resource.data.productId is string
        && request.resource.data.handler.id == request.auth.uid;
      
      // Phase 3: LOGISTICS UPDATE - logistics can update their own checkpoints
      allow update: if isLogistics()
        && resource.data.handler.id == request.auth.uid;
      
      // Phase 3: LOGISTICS DELETE - logistics can delete their own checkpoints
      allow delete: if isLogistics()
        && resource.data.handler.id == request.auth.uid;
    }

    // ===============================================================
    // Revoked Tokens Collection (Auth)
    // ===============================================================
    match /revokedTokens/{tokenHash} {
      // Backend can read to check if token is revoked
      allow read: if isAuthenticated();
      
      // Backend can write tokens on logout
      allow create: if isAuthenticated();
      
      // Delete handled by TTL
      allow delete: if false;
    }

    // ===============================================================
    // Users Collection (Auth)
    // ===============================================================
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isOwner(userId);
      
      // Backend writes via trusted SDK only
      allow write: if false;
    }

    // ===============================================================
    // Companies Collection (Admin)
    // ===============================================================
    match /companies/{companyId} {
      // Org members can read their own company
      allow read: if isAuthenticated()
        && request.auth.token.orgId == companyId;
      
      // Admins can read all companies
      allow read: if isAuditor();
      
      // Backend writes via trusted SDK only
      allow write: if false;
    }

    // ===============================================================
    // Deny everything else
    // ===============================================================
    match /{path=**} {
      allow read, write: if false;
    }
  }
}

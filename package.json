{
  "name": "chaintrace-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "client",
    "server",
    "blockchain"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "npm run dev --workspace client -- --port 3000 --host 0.0.0.0",
    "dev:backend": "PORT=4000 npm run dev --workspace server",
    "build": "npm run build --workspace client && npm run build --workspace server",
    "lint": "npm run lint --workspace client",
    "test": "npm run test --workspace server && npm run test --workspace blockchain"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@google/generative-ai": "^0.24.1",
    "chai": "^4.5.0",
    "concurrently": "^9.2.1",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "firebase": "^12.12.0",
    "framer-motion": "^12.38.0",
    "ganache": "^7.9.2",
    "hardhat": "^2.28.6",
    "lucide-react": "^1.8.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "web3": "^4.16.0",
    "zod": "^3.25.76"
  }
}
